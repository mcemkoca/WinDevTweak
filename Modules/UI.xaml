<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinDevTweak" Height="750" Width="1150"
        WindowStartupLocation="CenterScreen"
        Background="#1e1e1e" Foreground="#cccccc"
        FontFamily="Segoe UI" FontSize="13">
    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="FontSize" Value="13"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#252526"/>
            <Setter Property="Foreground" Value="#cccccc"/>
            <Setter Property="BorderBrush" Value="#3e3e42"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,8"/>
            <Setter Property="Margin" Value="4"/>
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="200"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="260"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Title Bar -->
        <Border Grid.ColumnSpan="2" Background="#252526" Padding="18,12" BorderBrush="#3e3e42" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="WinDevTweak" FontSize="18" FontWeight="Bold" Foreground="#00ff88"/>
                <TextBlock Text=" - Windows Developer Ultimate Tweak Suite" FontSize="14" Foreground="#888888" Margin="8,2,0,0"/>
            </StackPanel>
        </Border>

        <!-- Left: Categories -->
        <Border Grid.Row="1" Background="#1e1e1e" BorderBrush="#3e3e42" BorderThickness="0,0,1,0" Margin="0">
            <ListBox x:Name="CategoryList" Background="Transparent" BorderThickness="0"/>
        </Border>

        <!-- Right: Tweak List -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                <Button x:Name="BtnSelectAll" Content="☑ Select All"/>
                <Button x:Name="BtnDeselectAll" Content="☐ Deselect All"/>
                <Button x:Name="BtnRestorePoint" Content="🔒 Create Restore Point"/>
            </StackPanel>
            <Border Grid.Row="1" BorderBrush="#3e3e42" BorderThickness="1" Background="#252526">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="TweakPanel" Margin="8"/>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- Bottom: Log & Actions -->
        <Grid Grid.Row="2" Grid.ColumnSpan="2" Margin="15,0,15,15">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <TextBlock Text="📋 Execution Log" FontWeight="Bold" Margin="0,0,0,6" Foreground="#cccccc"/>
            <Border Grid.Row="1" Background="#0e0e0e" BorderBrush="#3e3e42" BorderThickness="1">
                <RichTextBox x:Name="LogBox" Background="Transparent" Foreground="#cccccc"
                             FontFamily="Consolas" FontSize="11" IsReadOnly="True"
                             VerticalScrollBarVisibility="Auto" BorderThickness="0"
                             Padding="8"/>
            </Border>
            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
                <TextBlock x:Name="SelectionLabel" Text="0 selected" Foreground="#888888" Margin="0,0,15,0" VerticalAlignment="Center" FontSize="12"/>
                <ProgressBar x:Name="ProgressBar" Width="300" Height="20" Margin="0,0,15,0" Visibility="Collapsed"/>
                <Button x:Name="BtnApply" Content="Apply Selected" Background="#00ff88" Foreground="#1e1e1e" FontWeight="Bold" FontSize="14" Padding="20,10"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
