<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="WinDevTweak" Height="800" Width="1200"
        WindowStartupLocation="CenterScreen"
        Background="#0d1117" Foreground="#e6edf3"
        FontFamily="Segoe UI Variable Display, Segoe UI, sans-serif" FontSize="13"
        WindowStyle="None" AllowsTransparency="True" ResizeMode="CanResizeWithGrip">
    <Window.Resources>
        <Style TargetType="ListBoxItem">
            <Setter Property="Foreground" Value="#8b949e"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Padding" Value="16,12"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="BorderThickness" Value="0"/>
        </Style>
        <Style TargetType="Button">
            <Setter Property="Background" Value="#21262d"/>
            <Setter Property="Foreground" Value="#e6edf3"/>
            <Setter Property="BorderBrush" Value="#30363d"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Margin" Value="6,0,0,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
        </Style>
    </Window.Resources>
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Custom Title Bar -->
        <Border Grid.ColumnSpan="2" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                    <TextBlock Text="WinDevTweak" FontSize="15" FontWeight="SemiBold" Foreground="#2ea043"/>
                    <TextBlock Text="v1.1.0" FontSize="11" Foreground="#484f58" Margin="8,2,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="BtnMinimize" Content="-" Width="40" Height="32" Padding="0" Margin="4,0"/>
                    <Button x:Name="BtnClose" Content="x" Width="40" Height="32" Padding="0" Background="#da3633" BorderBrush="#f85149" Foreground="#ffffff"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Left Sidebar -->
        <Grid Grid.Row="1" Background="#0d1117">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Border Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,1,1" Padding="12,10">
                <TextBox x:Name="SearchBox" Background="#0d1117" Foreground="#e6edf3" BorderBrush="#30363d"
                         CaretBrush="#e6edf3" Padding="10,6" FontSize="12" BorderThickness="1"
                         Text="Search tweaks..."/>
            </Border>
            <Border Grid.Row="1" Background="#161b22" BorderBrush="#30363d" BorderThickness="0,0,1,1" Padding="16,10">
                <TextBlock Text="CATEGORIES" FontSize="10" FontWeight="Bold" Foreground="#484f58" LetterSpacing="2"/>
            </Border>
            <Border Grid.Row="2" BorderBrush="#30363d" BorderThickness="0,0,1,0">
                <ListBox x:Name="CategoryList" Background="Transparent" BorderThickness="0"/>
            </Border>
        </Grid>

        <!-- Main Content -->
        <Grid Grid.Row="1" Grid.Column="1" Background="#0d1117">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="210"/>
            </Grid.RowDefinitions>

            <!-- Toolbar -->
            <Border Background="#0d1117" BorderBrush="#30363d" BorderThickness="0,0,0,1" Padding="20,14">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Button x:Name="BtnSelectAll" Content="Select All" Background="#21262d"/>
                    <Button x:Name="BtnDeselectAll" Content="Deselect All" Background="#21262d"/>
                    <Rectangle Width="1" Height="24" Fill="#30363d" Margin="12,0"/>
                    <Button x:Name="BtnRestorePoint" Content="Restore Point" Background="#1f6feb" BorderBrush="#388bfd" Foreground="#ffffff"/>
                    <Button x:Name="BtnUndo" Content="Undo" Background="#da3633" BorderBrush="#f85149" Foreground="#ffffff"/>
                    <Rectangle Width="1" Height="24" Fill="#30363d" Margin="12,0"/>
                    <Button x:Name="BtnSaveProfile" Content="Save" Background="#21262d"/>
                    <Button x:Name="BtnLoadProfile" Content="Load" Background="#21262d"/>
                    <TextBlock x:Name="SelectionLabel" Text="0 selected" Foreground="#484f58" Margin="20,0,0,0" VerticalAlignment="Center" FontSize="12"/>
                </StackPanel>
            </Border>

            <!-- Tweak Grid -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20,16,20,0">
                <WrapPanel x:Name="TweakPanel" Orientation="Horizontal"/>
            </ScrollViewer>

            <!-- Bottom Panel -->
            <Grid Grid.Row="2" Margin="20,12,20,20">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBlock Text="Execution Log" FontSize="11" FontWeight="Bold" Foreground="#8b949e"/>
                    <TextBlock x:Name="StatusLabel" Text="Ready" FontSize="11" Foreground="#484f58" Margin="12,0,0,0"/>
                </StackPanel>
                <Border Grid.Row="1" Background="#161b22" BorderBrush="#30363d" BorderThickness="1" CornerRadius="4">
                    <RichTextBox x:Name="LogBox" Background="Transparent" Foreground="#e6edf3"
                                 FontFamily="Cascadia Mono, Consolas" FontSize="11" IsReadOnly="True"
                                 VerticalScrollBarVisibility="Auto" BorderThickness="0"
                                 Padding="12"/>
                </Border>
                <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <ProgressBar x:Name="ProgressBar" Width="280" Height="8" Margin="0,0,16,0" Visibility="Collapsed"
                                 Background="#21262d" BorderBrush="#30363d" Foreground="#2ea043"/>
                    <Button x:Name="BtnApply" Content="Apply Selected" Background="#2ea043" BorderBrush="#3fb950" Foreground="#ffffff" FontWeight="SemiBold" FontSize="13" Padding="28,12"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
